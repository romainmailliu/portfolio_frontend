# Copier vers `.env.local` pour le dev local (Next.js ne lit PAS ce fichier).
# --- Dashboard privé (/dashboard) ---
DASHBOARD_PASSWORD=
# Chaîne longue aléatoire ; openssl rand -hex 32 — signe les cookies de session (la changer déconnecte tout le monde).
DASHBOARD_SESSION_SECRET=

# Host par défaut (repli pour ATS / Amidou / Portfolio si *_ATS_SEDUCTION / *_AMIDOU absents)
POSTHOG_HOST=https://eu.posthog.com

# --- Carte « ATS Seduction » (suffixe ATS_SEDUCTION) ---
POSTHOG_PROJECT_ID_ATS_SEDUCTION=
POSTHOG_API_KEY_ATS_SEDUCTION=
POSTHOG_HOST_ATS_SEDUCTION=https://eu.posthog.com
GSC_SITE_URL_ATS_SEDUCTION=https://ats-seduction.vercel.app/
# Anciens noms encore lus si les *_ATS_SEDUCTION ci-dessus sont vides :
# POSTHOG_PROJECT_ID_ATS=
# GSC_SITE_URL_ATS=

# --- Carte « Amidou » — autre compte PostHog (suffixe AMIDOU, pas de repli sur POSTHOG_API_KEY) ---
POSTHOG_PROJECT_ID_AMIDOU=
POSTHOG_API_KEY_AMIDOU=
POSTHOG_HOST_AMIDOU=https://eu.posthog.com
GSC_SITE_URL_AMIDOU=https://www.amidou.eu/

# --- Carte « Portfolio » (sans suffixe — utilise uniquement POSTHOG_API_KEY) ---
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID_PORTFOLIO=

# --- Search Console : un token OAuth Bearer pour toutes les propriétés ---
GSC_ACCESS_TOKEN=
GSC_SITE_URL_PORTFOLIO=https://www.romainmailliu.com/
